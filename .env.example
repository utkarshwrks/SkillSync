# ──────────────────────────────────────────────────────────────────
# SkillSync environment variables
# Copy this file to `.env` and fill in your own values.
# `.env` is git-ignored and is the ONLY place secrets/API keys live.
# ──────────────────────────────────────────────────────────────────

# --- Django core ---
DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app

# --- Database ---
# Leave unset to use SQLite (zero-config, great for local dev).
# For production set a full URL, e.g.:
#   postgres://USER:PASSWORD@HOST:5432/DBNAME
#   mysql://USER:PASSWORD@HOST:3306/DBNAME
# DATABASE_URL=

# --- CORS / CSRF (comma separated origins of the frontend) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- AI: Google Gemini (free tier) ---
# Get a key at https://aistudio.google.com/app/apikey
# If left blank, SkillSync uses a built-in offline analyser instead.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- Optional: USAJobs API (free, requires registration) ---
USAJOBS_API_KEY=
USAJOBS_USER_AGENT=

# --- Optional: Adzuna (free) — enables LOCAL Indian job listings ---
# Register for free keys at https://developer.adzuna.com/
# ADZUNA_COUNTRY uses ISO codes: "in" = India (default), "us", "gb", etc.
# Without keys, the Adzuna source is skipped and remote boards still work.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=in

# --- Frontend ---
# Base URL the React app uses to reach the API.
REACT_APP_API_URL=http://127.0.0.1:8000/api
