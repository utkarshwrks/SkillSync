{
  "name": "skillsync",
  "version": "1.0.0",
  "private": true,
  "description": "SkillSync — resume intelligence & skill-based job matching (Django REST + React).",
  "scripts": {
    "frontend": "npm --prefix frontend start",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:install": "npm --prefix frontend install",
    "backend": "cd backend && python manage.py runserver",
    "backend:migrate": "cd backend && python manage.py migrate",
    "backend:install": "pip install -r backend/requirements.txt"
  }
}
